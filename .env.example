# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Bank Legal Advisor
APP_VERSION=1.0.0
APP_ENV=development

# ── LLM (Claude API) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-api-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TEMPERATURE=0.0
CLAUDE_MAX_TOKENS=8096

# ── Application database (SQLAlchemy async) ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bank_legal_advisor

# ── Agent state checkpointer (durable resume for clarifications) ──────────────
# memory   → in-process only (state lost on restart, single instance)
# postgres → shared, durable; required for resume + multiple replicas
CHECKPOINTER_BACKEND=memory
# Defaults to DATABASE_URL when blank; the SQLAlchemy driver suffix is stripped.
# CHECKPOINT_DATABASE_URL=postgresql://user:password@localhost:5432/bank_legal_advisor
CHECKPOINT_POOL_MAX_SIZE=10

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector store (ChromaDB) ───────────────────────────────────────────────────
# embedded → local on-disk files (single instance)
# http     → shared Chroma server (run: chroma run --host 0.0.0.0 --port 8000)
CHROMA_MODE=embedded
CHROMA_PATH=./data/chromadb
CHROMA_COLLECTION=legislation_articles
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false

# ── Lexical (BM25) index ──────────────────────────────────────────────────────
# Seconds between cross-process staleness checks against the shared corpus.
LEXICAL_REFRESH_SECONDS=30

# ── Agent behaviour ───────────────────────────────────────────────────────────
MAX_CRITIQUE_RETRIES=2
GRAPH_K_DEPTH=2
SIMILARITY_N_RESULTS=5